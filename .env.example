# ── Supabase ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Telnyx (fax) ───────────────────────────────────────────────────────────────
# Get these from app.telnyx.com → API Keys / Fax connections
TELNYX_API_KEY=KEY0123456789_your_key_here
TELNYX_CONNECTION_ID=123456789          # Your Telnyx Fax Application ID
TELNYX_FROM_NUMBER=+15551234567         # Your Telnyx fax-capable phone number

# ── Resend (email) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# For dev/testing you can use:  onboarding@resend.dev  (no domain needed)
# For production, verify your own domain in Resend dashboard
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── App URL (used to build Telnyx webhook callback URL) ────────────────────────
# Local dev:  http://localhost:3000
# Production: https://fubcbs.makotechs.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cloudflare Turnstile (bot protection) ─────────────────────────────────────
# Get from dash.cloudflare.com → Turnstile → your widget
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAC...
TURNSTILE_SECRET_KEY=0x4AAAAAAC...

# ── Upstash Redis (rate limiting — 3 submissions/IP/hour) ─────────────────────
# Get from console.upstash.com → your Redis DB → REST tab
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
